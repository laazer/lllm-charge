{
  "name": "llm-charge",
  "version": "1.0.0",
  "description": "Supercharge local LLMs with semantic code intelligence and recursive reasoning to minimize API costs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "llm-charge": "./dist/bin/llm-charge.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "copy-assets": "cp -r src/assets/* dist/assets/ 2>/dev/null || true",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:performance": "jest tests/performance --testTimeout=120000",
    "test:e2e": "jest tests/integration/end-to-end.test.ts --testTimeout=180000",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist build .llm-charge-cache coverage"
  },
  "keywords": [
    "llm",
    "local-ai",
    "code-intelligence", 
    "semantic-search",
    "recursive-reasoning",
    "api-optimization",
    "cost-reduction"
  ],
  "author": "LLM-Charge Contributors",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "commander": "^12.0.0",
    "figlet": "^1.8.0",
    "ignore": "^7.0.4",
    "ml-matrix": "^6.12.1",
    "node-sqlite3-wasm": "^0.8.0",
    "ollama": "^0.5.0",
    "openai": "^4.0.0",
    "picomatch": "^4.0.3",
    "python-shell": "^5.0.0",
    "simple-git": "^3.27.0",
    "tree-sitter-wasms": "^0.1.0",
    "web-tree-sitter": "^0.20.0",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.0",
    "@types/picomatch": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "sqlite-vss": "^0.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.11"
  }
}