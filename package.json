{
  "name": "llm-charge",
  "version": "1.0.0",
  "description": "Supercharge local LLMs with semantic code intelligence and recursive reasoning to minimize API costs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "llm-charge": "./dist/bin/llm-charge.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "build:react": "NODE_ENV=production vite build",
    "build:react:dev": "NODE_ENV=development vite build",
    "build:analyze": "ANALYZE=true NODE_ENV=production vite build",
    "build:production": "npm run build && npm run build:react",
    "dev": "tsc --watch",
    "dev:react": "vite --host",
    "dev:server": "npx tsx src/server/working-server.mjs",
    "dev:server:comprehensive": "node src/server/comprehensive-working-server.mjs",
    "dev:full": "concurrently \"npm run dev:server:comprehensive\" \"npm run dev:react\"",
    "dev:full:basic": "concurrently \"npm run dev:server\" \"npm run dev:react\"",
    "start": "node dist/index.js",
    "start:react": "vite preview",
    "preview:production": "npm run build:production && vite preview",
    "copy-assets": "/bin/cp -rf src/assets/* dist/assets/ 2>/dev/null || true && mkdir -p dist/src/server && /bin/cp -f src/server/*.mjs dist/src/server/ 2>/dev/null || true",
    "setup": "npx tsx src/setup/load-defaults.ts",
    "setup:force": "npx tsx -e \"import { loadDefaultsFromCLI } from './src/setup/load-defaults'; loadDefaultsFromCLI('http://localhost:3001', 'main-1773934155652', { overwriteExisting: true })\"",
    "download:samples": "bash scripts/download-sample-projects.sh",
    "onboard:samples": "bash scripts/onboard-sample-projects.sh",
    "postinstall": "npm run setup",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:performance": "jest tests/performance --testTimeout=120000",
    "test:e2e": "jest tests/integration/end-to-end.test.ts --testTimeout=180000",
    "test:react": "jest --config=jest.config.react.cjs",
    "test:react:unit": "jest --config=jest.config.react.cjs tests/unit/react",
    "test:react:integration": "jest --config=jest.config.react.cjs tests/integration/react-*",
    "test:react:performance": "jest --config=jest.config.react.cjs tests/performance/websocket-*",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:react": "jest --config=jest.config.react.cjs --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:all": "npm run test && npm run test:react",
    "lint": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist build .llm-charge-cache coverage",
    "local": "bash scripts/local-deploy.sh start",
    "local:build": "bash scripts/local-deploy.sh start --build",
    "local:stop": "bash scripts/local-deploy.sh stop",
    "local:restart": "bash scripts/local-deploy.sh restart",
    "local:status": "bash scripts/local-deploy.sh status",
    "local:logs": "bash scripts/local-deploy.sh logs",
    "zip": "bash scripts/create-release-zip.sh",
    "zip:win": "scripts\\create-release-zip.bat",
    "update": "bash scripts/pseudo-git-update.sh",
    "update:dry-run": "bash scripts/pseudo-git-update.sh --dry-run",
    "update:backup": "bash scripts/pseudo-git-update.sh --backup",
    "update:force": "bash scripts/pseudo-git-update.sh --force",
    "update:win": "scripts\\pseudo-git-update.bat"
  },
  "keywords": [
    "llm",
    "local-ai",
    "code-intelligence",
    "semantic-search",
    "recursive-reasoning",
    "api-optimization",
    "cost-reduction"
  ],
  "author": "LLM-Charge Contributors",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.14.0",
    "commander": "^12.0.0",
    "figlet": "^1.8.0",
    "ignore": "^7.0.4",
    "ml-matrix": "^6.12.1",
    "node-cron": "^4.2.1",
    "node-sqlite3-wasm": "^0.8.0",
    "ollama": "^0.5.0",
    "openai": "^4.0.0",
    "picomatch": "^4.0.3",
    "python-shell": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.13.2",
    "simple-git": "^3.27.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tree-sitter-wasms": "^0.1.0",
    "web-tree-sitter": "^0.20.0",
    "ws": "^8.19.0",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/figlet": "^1.5.8",
    "@types/jest": "^29.5.12",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.19.15",
    "@types/node-fetch": "^2.6.13",
    "@types/picomatch": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0",
    "sqlite-vss": "^0.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.11"
  }
}
